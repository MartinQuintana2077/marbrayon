          <a href="#" data-target="mobile-demo" class="sidenav-trigger"><i class="material-icons">menu</i></a>
          <ul class="right hide-on-med-and-down">
            <li>
            </li>
            <li><a href="/logout">Cerrar sesión</a></li>
            <li><a href="inicio">Cambiar usuario</a></li>
          </ul>
        </div>
      </nav>

      <ul class="sidenav" id="mobile-demo">
        <li>
            <div class="user-view">
                <div class="background">
                    <img style="height: 260px; width: 300px;" src="Ima/fondo11.png">
                </div>
                <a href="#user"><img class="circle" src="Ima/marti.png"></a>
                <a href="#name"><span class="white-text name"><%= user.nombre_usuario %></span></a>
                <a href="#email"><span class="white-text email"><%= user.email_usuario %></span></a>
            </div>
        </li>
        <li><a href="#!"><i class="material-icons">cloud</i>Mi Usuario</a></li>
        <li><a href="/logout">Cerrar sesión</a></li>
        <li><div class="divider"></div></li>
        <li><a class="subheader" href="inicio">Cambiar Usuario</a></li>
        <li><a class="waves-effect" href="admin">Volver Inicio</a></li>
        
    </ul>

<div style="background-color: #bbdefb;">
    <h1>Lista de Productos</h1>
    <table style="background-color: white;" class="responsive-table">
        <thead>
            <tr style="font-size:30px;">
                <th>ID</th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Descripción</th>
                <th>Equipo</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% producto.forEach(function(producto) { %>
            <tr style="font-size:21px;">
                <td><%= producto.id_producto %></td>
                <td><%= producto.nombre_producto %></td>
                <td><%= producto.precio %></td>
                <td><%= producto.stock %></td>
                <td><%= producto.descripcion %></td>
                <td><%= producto.equipo %></td>
                <td>
                    <form action="/editarProducto/<%= producto.id_producto %>" method="get">
                        <button class="waves-effect waves-light btn blue" type="submit">Editar <i class="material-icons right">edit</i></button>
                    </form>
                    <form action="/borrar4" method="post">
                        <input type="hidden" name="id_producto" value="<%= producto.id_producto %>">
                        <button class="waves-effect waves-light btn red" type="submit">Borrar<i class="material-icons right">delete</i></button>
                    </form>
                </td>
            </tr>
            <% }); %>
        </tbody>
    </table>
    <div style="background-color: white;">
      <br>
        <h1 style="background-color: #bbdefb;border:solid black;">REGISTRO DE PRODUCTO</h1>
        <form id="registerForm" method="post" action="/crearProd">
            <div class="reg2">
                <input type="text" id="nombre_producto" name="nombre_producto" required>
                <label style="font-size:20px;" for="nombre_producto">Nombre del producto</label>
            </div>
            <div class="reg2">
                <input type="number" id="precio" name="precio" required>
                <label style="font-size:20px;" for="precio">precio del producto</label>
            </div>
            <div class="reg2">
                <input type="number" id="stock" name="stock" required>
                <label style="font-size:20px;" for="stock">stock del producto</label>
            </div>
            <div class="reg2">
                <input type="text" id="descripcion" name="descripcion" required>
                <label style="font-size:20px;" for="descripcion">descripcion del producto</label>
            </div>
            <div class="reg2">
                <input type="text" id="equipo" name="equipo" required>
                <label style="font-size:20px;" for="equipo">equipo del producto</label>
            </div>
            <input type="submit" value="Registrar producto">
            
        </form>
    </div>
    <br>
  
      <div  style="width:60%;" class="col s1"> <a href="mantenedorUsu" class="waves-effect waves-light btn-large" style=" border-radius:5%;">Administrar usuarios</a></div>
      <br>
     
      <div style="width:50%;" class="col s1"><a href="mantenedorVen" class="waves-effect waves-light btn-large" style="border-radius:5%;">Administrar ventas</a></div>
      <br>
</div>

