<!DOCTYPE html>
<html>
<head>
    <title>CARRITO</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Import Google Icon Font -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <!-- Import materialize.css -->
    <link type="text/css" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link rel="stylesheet" href="css/Css.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bodyCarrito">
    <div class="carrito1">
        <h1>Carrito de Compras</h1>
        <table >
            <thead>
                <tr>
                    <th>Nombre del Producto</th>
                    <th>Cantidad</th>
                    <th>Precio Total</th>
                </tr>
            </thead>
            <tbody>
                <% if (carritos && carritos.length > 0) { %>
                    <% carritos.forEach(function(carrito) { %>
                        <tr>
                            <td><%= carrito.nombre_producto %></td>
                            <td><%= carrito.cantidad %></td>
                            <td>$<%= carrito.precio_total.toFixed(2) %></td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="3">No hay productos en el carrito</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
        <style>
            .card {
                margin-bottom: 20px;
            }
        </style>
       <div class="total-container">
        <h3 style="color: white;">Total: $<%= precioTotal.toFixed(2) %></h3>
        <h3 style="color: white;">Total con IVA (19%): $<%= precioConIVA.toFixed(2) %></h3>
       

        <form method="POST" action="/carrito/vaciar" id="vaciarCarritoForm">
            <button type="button" onclick="vaciarCarrito()">Vaciar Carrito</button>
        </form>
        <br>
        <br>

        <form action="/trans" method="post">
            <input type="hidden" name="amount" value="<%= precioTotal.toFixed(2) %>">
            <input type="hidden" name="sessionId" value="yony">
            <input type="hidden" name="buyOrder" value="12345">
            <input type="hidden" name="returnUrl" value="http://localhost:3000/Boleta">
            <button type="submit" class="waves-effect waves-light btn">transb</button>
        </form>
        <br>
        <br>

        <form method="POST" action="/ventas/procesar" id="pagarForm">
            <button type="button" onclick="pagarCarrito()">Pagar</button>
        </form>
        <br>
        <br>

        <button onclick="printBoleta()">Imprimir Boleta</button>
    </div>
    <a href="/index" style="background: linear-gradient(to bottom, #17202A, #34495E)" class="btn">Volver al Inicio</a>
</div>

    <div id="boletaPopup" style="display:none; z-index: 1000; position: fixed; left: 50%; top: 50%; transform: translate(-50%, -50%); background: white; padding: 20px; border: 1px solid black;">
        <h2>Boleta de Compra</h2>
        <p>Nombre del Sitio Web: MarBraYon</p>
        <p>Fecha: <span id="boletaFecha"></span></p>
        <table>
            <thead>
                <tr>
                    <th>Nombre del Producto</th>
                    <th>Cantidad</th>
                    <th>Precio Total</th>
                </tr>
            </thead>
            <tbody id="boletaDetalles">
                <% if (carritos && carritos.length > 0) { %>
                    <% carritos.forEach(function(carrito) { %>
                        <tr>
                            <td><%= carrito.nombre_producto %></td>
                            <td><%= carrito.cantidad %></td>
                            <td>$<%= carrito.precio_total.toFixed(2) %></td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>
        <h3>Total: $<span id="boletaTotal"><%= precioTotal.toFixed(2) %></span></h3>
        <h3>Total con IVA (19%): $<span id="boletaTotalConIVA"><%= precioConIVA.toFixed(2) %></span></h3>
        <button onclick="cerrarBoleta()">Cerrar</button>



       



    </div>


    

    <script>
        function printBoleta() {
            const fecha = new Date();
            document.getElementById('boletaFecha').innerText = fecha.toLocaleString();
            document.getElementById('boletaPopup').style.display = 'block';
        }

        function cerrarBoleta() {
            document.getElementById('boletaPopup').style.display = 'none';
        }
    </script>

<script>
    function printBoleta() {
        const fecha = new Date();
        document.getElementById('boletaFecha').innerText = fecha.toLocaleString();
        document.getElementById('boletaPopup').style.display = 'block';
    }

    function cerrarBoleta() {
        document.getElementById('boletaPopup').style.display = 'none';
    }

    function vaciarCarrito() {
        Swal.fire({
            title: '¿Estás seguro?',
            text: "¡No podrás revertir esto!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Sí, vaciar carrito'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('vaciarCarritoForm').submit();
            }
        })
    }

    function pagarCarrito() {
        Swal.fire({
            title: 'Pago realizado',
            text: 'Se realizó el pago correctamente',
            icon: 'success',
            confirmButtonText: 'Aceptar'
        }).then(() => {
            document.getElementById('pagarForm').submit();
        });
    }

   
</script>
</body>
</html>



