          <a href="#" data-target="mobile-demo" class="sidenav-trigger"><i class="material-icons">menu</i></a>
          <ul class="right hide-on-med-and-down">
            <li>
            </li>
            <li><a href="/logout">Cerrar sesión</a></li>
            <li><a href="inicio">Cambiar usuario</a></li>
          </ul>
        </div>
      </nav>

      <ul class="sidenav" id="mobile-demo">
        <li>
            <div class="user-view">
                <div class="background">
                    <img style="height: 260px; width: 300px;" src="Ima/fondo11.png">
                </div>
                <a href="#user"><img class="circle" src="Ima/marti.png"></a>
                <a href="#name"><span class="white-text name"><%= user.nombre_usuario %></span></a>
                <a href="#email"><span class="white-text email"><%= user.email_usuario %></span></a>
            </div>
        </li>
        <li><a href="#!"><i class="material-icons">cloud</i>Mi Usuario</a></li>
        <li><a href="/logout">Cerrar sesión</a></li>
        <li><div class="divider"></div></li>
        <li><a class="subheader" href="inicio">Cambiar Usuario</a></li>
        <li><a class="waves-effect" href="admin">Volver Inicio</a></li>
        
    </ul>




    <div style="background-color: #ffffff;">
        <h1>Lista de ventas</h1>
        <table class="responsive-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>ID PRODUCTO</th>
                    <th>ID CLIENTE</th>
                    <th>CANTIDAD</th>
                    <th>FECHA DE LA VENTA</th>
                    <th>ACCIONES</th>
                </tr>
            </thead>
            <tbody>
                <% if (venta && venta.length > 0) { %>
                    <% venta.forEach(function(venta) { %>
                        <tr>
                            <td><%= venta.id_venta %></td>
                            <td><%= venta.id_producto %></td>
                            <td><%= venta.id_usuario %></td>
                            <td><%= venta.cantidad %></td>
                            <td><%= venta.fecha %></td>
                            <td>
                                <form action="/editarVen/<%= venta.id_venta %>" method="get" style="display: inline;">
                                    <button class="waves-effect waves-light btn blue" type="submit">Editar <i class="material-icons right">edit</i></button>
                                </form>
                                <form action="/borrar5" method="post" style="display: inline;">
                                    <input type="hidden" name="id_venta" value="<%= venta.id_venta %>">
                                    <button class="waves-effect waves-light btn red" type="submit">Borrar <i class="material-icons right">delete</i></button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="6">No hay ventas disponibles</td>
                    </tr>
                <% } %>
            </tbody>
        </table>

        <h1>REGISTRO DE VENTA</h1>
        <form id="registerForm" method="post" action="/crearVen">
            <div class="input-field">
                <input type="number" id="id_producto" name="id_producto" required>
                <label for="id_producto">ID del producto</label>
            </div>
            <div class="input-field">
                <input type="number" id="id_cliente" name="id_cliente" required>
                <label for="id_cliente">ID del cliente</label>
            </div>
            <div class="input-field">
                <input type="number" id="cantidad" name="cantidad" required>
                <label for="cantidad">Cantidad</label>
            </div>
            <div class="input-field">
                <input type="datetime-local" id="fecha" name="fecha" required>
                <label for="fecha"></label>
            </div>
            <button class="btn waves-effect waves-light" type="submit">Registrar venta</button>
        </form>

        <div class="iniciar-sesion2">
            ¿Quieres volver? 
            <a href="admin" style="color: black; font-size: 22px">Vuelve</a>
        </div>
    </div>
